# Xero OAuth2 Web Application credentials
# Create a Web Application at https://developer.xero.com/app/manage
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here

# Initial refresh token — obtain once via the Xero API Explorer:
# https://api-explorer.xero.com
# After first startup the server writes the rotated token to XERO_TOKEN_FILE,
# so this env var is only used when no token file exists.
XERO_REFRESH_TOKEN=your_refresh_token_here

# Optional: override the default token file path (~/.xero-mcp/refresh_token)
# XERO_TOKEN_FILE=/path/to/your/refresh_token

# -- Token persistence backend ------------------------------------------------------------------
# Controls where the rotated refresh token is stored.
# "file" (default): writes to XERO_TOKEN_FILE (local/stdio use).
# "redis": writes to a Redis key (deployed/HTTP use; requires REDIS_URL).
# XERO_TOKEN_STORE=file

# Redis key name for the refresh token when XERO_TOKEN_STORE=redis.
# XERO_TOKEN_REDIS_KEY=xero:refresh_token

# -- OSB HTTP Mode (src/http/server.ts) --------------------------------------------------------
# These variables are only used by the HTTP entry point (dist/http/server.js).
# The stdio entry (dist/index.js) ignores them.

# One of: local | development | production
ENVIRONMENT=local

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -- Server bind -------------------------------------------------------------------------------
MCP_BIND_HOST=0.0.0.0
MCP_BIND_PORT=8000

# -- Local dev auth ----------------------------------------------------------------------------
# Required when ENVIRONMENT=local. Use a random string; never a real secret.
DEV_BEARER_TOKEN=changeme-replace-with-a-random-string

# -- Entra ID auth (required when ENVIRONMENT=development or production) -----------------------
# Token verification uses Entra's JWKS public keys (no shared secret required).
# DCR-issued client secrets are managed by ProxyOAuthServerProvider and persisted in Redis.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# Public HTTPS base URL of this server -- used as the OAuth issuer/redirect URI.
# Required when ENVIRONMENT != "local".
# Example: https://xero-mcp.tail-xxxx.ts.net
MCP_SERVER_URL=

# Scopes required on incoming Entra tokens. Comma-separated, no spaces.
# REQUIRED when ENVIRONMENT != "local".
# Example: mcp
ENTRA_REQUIRED_SCOPES=

# -- Redis (required when ENVIRONMENT != "local") ---------------------------------------------
# Connection URL for the Redis-compatible store (Valkey, Redis, etc).
REDIS_URL=redis://localhost:6379/0

# -- Session management ------------------------------------------------------------------------
# Idle timeout in seconds before a session is evicted. Default: 1800 (30 min).
# MCP_SESSION_IDLE_TIMEOUT_SECONDS=1800

# Maximum concurrent MCP sessions. New initialize requests return 503 at cap.
# MCP_MAX_SESSIONS=100
